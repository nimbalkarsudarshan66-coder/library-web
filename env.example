# ============================================================
#  .env.example — Saraswati Library
#
#  Copy this to .env for local development:
#    cp .env.example .env
#
#  PRODUCTION: Do NOT use .env on production.
#  Set all variables as real server environment variables:
#  • cPanel: Software → PHP Config → Set ENV variables
#  • VPS:    export VAR=value  (in /etc/environment or .bashrc)
#  • Nginx:  fastcgi_param VAR value; (inside server block)
#
#  The .env file is blocked by .htaccess and listed in .gitignore
#  so it CANNOT be committed or downloaded by users.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=CHANGE_THIS_NOW
DB_NAME=saraswati_library
DB_PORT=3306

# ── UPI Payment ──────────────────────────────────────────────
# Your UPI Virtual Payment Address (VPA) — stays server-side only
UPI_VPA=pratikshingare2002@okicici
UPI_NAME=Saraswati Library
# UPI_MERCHANT_CODE=

# ── Application ───────────────────────────────────────────────
APP_ENV=development
# APP_ENV=production           ← Change to this on live server

# Your live domain — used for CORS and security validation
APP_URL=https://yourdomain.com

# Admin alert email — receives notification when UTR is submitted
ADMIN_EMAIL=admin@yourdomain.com

# ── Security ─────────────────────────────────────────────────
# Set ALLOWED_ORIGIN to your exact live domain in production
# e.g. https://www.yourdomain.com  (no trailing slash)
ALLOWED_ORIGIN=https://yourdomain.com

# Rate limiting: max N requests per WINDOW seconds per IP per action
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# Payment session timeout in seconds (default: 900 = 15 minutes)
PAYMENT_TIMEOUT_SEC=900

# PHP session lifetime in seconds (default: 3600 = 1 hour)
SESSION_LIFETIME=3600

# ── Razorpay (optional — leave blank to use manual UTR flow) ──
# RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
# RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
# RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXX
